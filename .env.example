VECTOR_BACKEND=memory
EMBEDDER_BACKEND=mock
LLM_BACKEND=mock

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=tenant_

LLAMA_MODEL_PATH=
LLAMA_N_CTX=2048
LLAMA_THREADS=8
LLAMA_GPU_LAYERS=0

# Ollama tuning (used when LLM_BACKEND=llama_cpp in this setup)
OLLAMA_MODEL=phi3:mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_NUM_CTX=1024
OLLAMA_NUM_PREDICT=
OLLAMA_NUM_BATCH=
OLLAMA_NUM_THREAD=
OLLAMA_NUM_GPU=
OLLAMA_F16_KV=
OLLAMA_MIROSTAT=
OLLAMA_MIROSTAT_TAU=
OLLAMA_MIROSTAT_ETA=
OLLAMA_TEMPERATURE=0.0
OLLAMA_TOP_P=
OLLAMA_TOP_K=
OLLAMA_TIMEOUT_SECS=30

EMBED_DIM=384
MAX_CHUNK_WORDS=200
CHUNK_OVERLAP_WORDS=40
TOP_K=6
CACHE_TTL_SECONDS=120
MAX_CACHE_ITEMS=2048

AUTH_ENABLED=false
TENANT_CONFIG_PATH=tenants.json
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=audit.log
