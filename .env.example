VECTOR_BACKEND=memory
EMBEDDER_BACKEND=mock
LLM_BACKEND=mock

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=tenant_

LLAMA_MODEL_PATH=
LLAMA_N_CTX=2048
LLAMA_THREADS=8
LLAMA_GPU_LAYERS=0

EMBED_DIM=384
MAX_CHUNK_WORDS=200
CHUNK_OVERLAP_WORDS=40
TOP_K=6
CACHE_TTL_SECONDS=120
MAX_CACHE_ITEMS=2048

AUTH_ENABLED=false
TENANT_CONFIG_PATH=tenants.json
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=audit.log
